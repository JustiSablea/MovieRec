{
  "manifest_version": 3,
  "name": "MovieRec Assistant",
  "version": "0.1.0",
  "description": "Быстрые рекомендации фильмов на базе MovieLens и профиля MovieRec.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "MovieRec"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/movies.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
